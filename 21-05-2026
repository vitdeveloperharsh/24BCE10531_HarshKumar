CREATE TABLE products (
    pid int PRIMARY KEY,
    pname varchar(100) NOT NULL,
    prefNo int NOT NULL UNIQUE,
    cid int,
    CONSTRAINT FK_CategoryProduct FOREIGN KEY (cid) REFERENCES category(cid) ON DELETE CASCADE ON UPDATE CASCADE
);

