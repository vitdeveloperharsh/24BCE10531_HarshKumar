DROP TABLE IF EXISTS toppers;
CREATE TABLE toppers(id int);
INSERT INTO toppers VALUES (1),(2);

SELECT worker_id, first_name, department FROM worker
WHERE worker_id IN (SELECT id FROM toppers);

SELECT SUM(salary), department FROM worker 
GROUP BY department 
ORDER BY SUM(salary) ASC LIMIT 2;

SELECT first_name, department, salary FROM worker
ORDER BY salary DESC LIMIT 1 OFFSET 1;

SELECT first_name, department, salary
FROM worker w1
WHERE salary = (
    SELECT DISTINCT salary FROM worker w2
    WHERE w1.department = w2.department
    ORDER BY salary DESC
    LIMIT 1 OFFSET 1
);

SELECT department, MAX(salary) 
FROM worker GROUP BY department;
