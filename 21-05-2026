CREATE DATABASE IF NOT EXISTS vitcampus;
USE vitcampus;

DROP TABLE IF EXISTS products;
DROP TABLE IF EXISTS category;

CREATE TABLE category (
    cid int PRIMARY KEY,
    cname varchar(100) NOT NULL
);

